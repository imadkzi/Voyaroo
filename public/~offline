<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fafafa" />
    <title>Voyaroo — Offline</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #fafafa;
        --surface: #ffffff;
        --text: #0a0a0a;
        --muted: #71717a;
        --border: rgba(24, 24, 27, 0.12);
        --primary: #ff385c;
        --shadow: 0 18px 45px rgba(24, 24, 27, 0.12);
      }
      @media (prefers-color-scheme: dark) {
        :root {
          color-scheme: dark;
          --bg: #141417;
          --surface: #1a1b1f;
          --text: #fafafa;
          --muted: #a1a1aa;
          --border: rgba(244, 244, 245, 0.14);
          --primary: #ff4d6d;
          --shadow: 0 18px 55px rgba(0, 0, 0, 0.55);
        }
      }
      html,
      body {
        height: 100%;
      }
      body {
        margin: 0;
        display: grid;
        place-items: center;
        padding: 16px;
        background: var(--bg);
        color: var(--text);
        font: 600 14px/1.45 ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica,
          Arial;
      }
      .card {
        width: min(100%, 360px);
        border-radius: 22px;
        border: 1px solid var(--border);
        background: color-mix(in oklab, var(--surface) 88%, transparent);
        box-shadow: var(--shadow);
        padding: 16px;
      }
      h1 {
        margin: 0;
        font-size: 16px;
        font-weight: 900;
      }
      p {
        margin: 8px 0 0;
        color: var(--muted);
        font-weight: 650;
      }
      a {
        display: inline-flex;
        margin-top: 14px;
        height: 42px;
        padding: 0 16px;
        border-radius: 999px;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        color: #fff;
        background: var(--primary);
        font-weight: 800;
      }
    </style>
  </head>
  <body>
    <main class="card" role="status" aria-live="polite">
      <h1>You’re offline</h1>
      <p>
        Voyaroo can still show content you’ve opened recently. Some actions won’t work until you’re
        back online.
      </p>
      <a href="/">Go to trips</a>
    </main>
  </body>
</html>

