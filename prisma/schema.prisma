generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trip {
  id            String   @id @default(uuid()) @db.Uuid
  slug          String   @unique
  title         String
  subtitle      String   @default("")
  departureAt   DateTime? @map("departure_at") @db.Timestamptz(6)
  locationLabel String   @default("") @map("location_label")
  heroImageSrc  String   @default("") @map("hero_image_src")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  itineraryItems ItineraryItem[]
  checklistItems ChecklistItem[]
  outfitItems    OutfitItem[]

  @@map("trips")
  @@index([createdAt(sort: Desc)])
}

model ItineraryItem {
  id        String   @id @default(uuid()) @db.Uuid
  tripId    String   @map("trip_id") @db.Uuid
  dayNumber Int      @default(1) @map("day_number")
  title     String
  notes     String   @default("")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("itinerary_items")
  @@index([tripId, dayNumber, sortOrder, createdAt])
}

model ChecklistItem {
  id        String   @id @default(uuid()) @db.Uuid
  tripId    String   @map("trip_id") @db.Uuid
  label     String
  done      Boolean  @default(false)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("checklist_items")
  @@index([tripId, done, sortOrder, createdAt])
}

model OutfitItem {
  id        String   @id @default(uuid()) @db.Uuid
  tripId    String   @map("trip_id") @db.Uuid
  dayNumber Int      @default(1) @map("day_number")
  title     String
  items     String[] @default([])
  notes     String   @default("")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("outfit_items")
  @@index([tripId, dayNumber, sortOrder, createdAt])
}

