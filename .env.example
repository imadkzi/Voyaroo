# =============================================================================
# Voyaroo — Local Postgres (Node)
# =============================================================================
# Copy to `.env.local` for local dev. Never commit `.env.local`.
#
# 1) Start Postgres:
#    `npm run db:up`
#
# 2) Run migrations (creates tables):
#    `npm run db:migrate`
# =============================================================================

# Default local DB (matches docker-compose.yml)
DATABASE_URL="postgresql://voyaroo:voyaroo@localhost:54322/voyaroo?schema=public"

# Auth.js (required for login/session)
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Local callback base URL
NEXTAUTH_URL="http://localhost:3000"

# Optional: improves auto-selected hero images for locations
# Get from https://www.pexels.com/api/
# PEXELS_API_KEY=

# Optional: location autocomplete provider (Geoapify)
# Get from https://www.geoapify.com/
# NEXT_PUBLIC_GEOAPIFY_API_KEY=

# If testing on a real device over LAN, set this to your machine IP URL:
# NEXTAUTH_URL="http://192.168.x.x:3000"

